{
  "name": "@tgcmcp/thegamecrafter-mcp",
  "version": "1.0.0",
  "private": false,
  "description": "Bootstrap installer and MCP server for The Game Crafter Developer API",
  "type": "module",
  "bin": {
    "tgcmcp": "dist/install.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khenn/thegamecrafter-mcp.git"
  },
  "homepage": "https://github.com/khenn/thegamecrafter-mcp",
  "bugs": {
    "url": "https://github.com/khenn/thegamecrafter-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run clean:dist && npm run prepare:installer-assets && npm run build:installer-runtime && tsc -p tsconfig.json",
    "clean:dist": "tsx scripts/ci/clean-dist.ts --repo-root ..",
    "prepare:installer-assets": "tsx scripts/ci/prepare-installer-assets.ts --repo-root ..",
    "build:installer-runtime": "tsx scripts/ci/build-installer-runtime.ts --repo-root ..",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --loader tsx src/index.ts",
    "test": "vitest run",
    "test:integration:game-create-delete": "tsx scripts/dev/test-game-create-delete.ts",
    "test:integration:deck-bulk-create-cards": "tsx scripts/dev/test-deck-bulk-create-cards.ts",
    "test:integration:zch-manual-copy-e2e": "tsx scripts/dev/test-zch-manual-copy-e2e.ts",
    "test:integration:component-primitives": "tsx scripts/dev/test-component-primitives.ts",
    "test:integration:batch0-smoke-harness": "tsx scripts/dev/test-batch0-smoke-harness.ts",
    "test:integration:packaging-core": "tsx scripts/dev/test-packaging-core.ts",
    "test:integration:batch2-books-documents": "tsx scripts/dev/test-batch2-books-documents.ts",
    "test:integration:batch3-board-mat-surfaces": "tsx scripts/dev/test-batch3-board-mat-surfaces.ts",
    "test:integration:batch4-advanced-cut-and-dial": "tsx scripts/dev/test-batch4-advanced-cut-and-dial.ts",
    "test:integration:batch5-specialty-parts": "tsx scripts/dev/test-batch5-specialty-parts.ts",
    "test:integration:component-update-custom-dice": "tsx scripts/dev/test-component-update-custom-dice.ts",
    "test:integration:component-update-global-nondice": "tsx scripts/dev/test-component-update-global-nondice.ts",
    "test:integration:game-publish-unpublish": "tsx scripts/dev/test-game-publish-unpublish.ts",
    "report:component-matrix": "tsx scripts/dev/generate-component-capability-matrix.ts",
    "report:component-matrix:check": "tsx scripts/dev/generate-component-capability-matrix.ts --check",
    "claude:test": "tsx scripts/dev/run-claude-regression.ts --repo-root ..",
    "claude:test:smoke": "tsx scripts/dev/run-claude-regression.ts --repo-root .. --fixture ../tests/claude/fixtures/smoke.json",
    "claude:test:routing": "tsx scripts/dev/run-claude-regression.ts --repo-root .. --fixture ../tests/claude/fixtures/routing-minimal-context.json",
    "claude:test:guardrails": "tsx scripts/dev/run-claude-regression.ts --repo-root .. --fixture ../tests/claude/fixtures/family-guardrails.json",
    "claude:test:live": "tsx scripts/dev/run-claude-regression.ts --repo-root .. --fixture ../tests/claude/fixtures/live-sandbox.json",
    "claude:test:core": "npm run claude:test:smoke && npm run claude:test:routing && npm run claude:test:guardrails",
    "claude:test:all": "npm run claude:test:core && npm run claude:test:live",
    "skills:create": "tsx scripts/skills/create-skill-scaffold.ts --repo-root ..",
    "skills:validate": "tsx scripts/skills/validate-skill-package.ts --repo-root ..",
    "skills:test-triggers": "tsx scripts/skills/test-skill-triggers.ts --repo-root ..",
    "skills:test-fixtures": "tsx scripts/skills/test-skill-validator-fixtures.ts --repo-root ..",
    "skills:test": "npm run skills:validate && npm run skills:test-triggers && npm run skills:test-fixtures",
    "a5:test": "npm run report:component-matrix:check && npm run skills:test",
    "a5:test:claude": "npm run claude:test:core",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.8",
    "esbuild": "^0.25.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
